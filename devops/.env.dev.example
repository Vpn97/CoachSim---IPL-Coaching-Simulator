################################################################
# DEV environment template. Copy to devops/.env.dev and adjust.
################################################################

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Database (must match compose internal hostname `postgres`)
POSTGRES_DB=coachsim
POSTGRES_USER=coachsim
POSTGRES_PASSWORD=coachsim

# JWT — long random string in real envs
JWT_SECRET=dev-secret-change-me-dev-secret-change-me-dev-secret

# CORS — Angular dev server + local Traefik
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:4200

# Ingestion: mock for local demos
# To try the real CricAPI v2 integration in dev:
#   INGESTION_PROVIDER=external
#   EXTERNAL_API_BASE_URL=https://api.cricapi.com/v1
#   EXTERNAL_API_KEY=<your free key from https://cricapi.com/>
INGESTION_PROVIDER=mock
EXTERNAL_API_BASE_URL=https://api.cricapi.com/v1
EXTERNAL_API_KEY=

# --- Host port overrides ---------------------------------------------------
# Change these if something else on your machine is already using port 80,
# 8080, or 5432. The Angular SPA uses relative paths, so it just works
# whichever host port you pick for the frontend.
FRONTEND_HOST_PORT=80
BACKEND_HOST_PORT=8080
POSTGRES_HOST_PORT=5432
