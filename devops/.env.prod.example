################################################################
# PROD environment template. Copy to devops/.env.prod and fill in.
# DO NOT commit the real file (devops/.env.prod is gitignored).
################################################################

# Public DNS name pointing at the Traefik host
PUBLIC_HOST=coachsim.example.com

# Email used for Let's Encrypt certificate issuance
ACME_EMAIL=ops@example.com

# Database (use a strong password)
POSTGRES_DB=coachsim
POSTGRES_USER=coachsim
POSTGRES_PASSWORD=replace-with-a-strong-secret

# JWT — 64+ char random secret
JWT_SECRET=replace-with-a-very-long-random-secret-string

# Browser origin(s) allowed by the API
CORS_ALLOWED_ORIGINS=https://coachsim.example.com

# Real cricket API — defaults wired for cricapi.com v2 (https://cricapi.com)
# Sign up at https://cricapi.com/ for a free API key (100 req/day).
# For paid ball-by-ball, swap base-url + adapter for SportMonks / RapidAPI Cricbuzz.
INGESTION_PROVIDER=external
EXTERNAL_API_BASE_URL=https://api.cricapi.com/v1
EXTERNAL_API_KEY=replace-with-vendor-key

# Backend horizontal scale
BACKEND_REPLICAS=2

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Activate the Traefik service (it's behind the "proxy" compose profile so dev
# can run without it). Leave as-is for prod.
COMPOSE_PROFILES=proxy
