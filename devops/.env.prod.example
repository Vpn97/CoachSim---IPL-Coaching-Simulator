################################################################
# PROD environment template. Copy to devops/.env.prod and fill in.
# DO NOT commit the real file (devops/.env.prod is gitignored).
#
# This stack assumes a Traefik v2 instance is already running on
# the host (separate compose stack) with:
#   - external Docker network: traefik-network
#   - entrypoint `websecure` on :443
#   - certificate resolver named `myresolver` (Let's Encrypt HTTP-01)
#   - HTTP -> HTTPS redirect on entrypoint `web`
#
# Bring this stack up with:
#   docker compose -f devops/docker-compose.yml \
#                  -f devops/docker-compose.prod.yml \
#                  --env-file devops/.env.prod up -d
################################################################

# Public DNS name pointing at the Traefik host (used in Host(`...`) rules)
PUBLIC_HOST=coachsim.example.com

# Database (use a strong password)
POSTGRES_DB=coachsim
POSTGRES_USER=coachsim
POSTGRES_PASSWORD=replace-with-a-strong-secret

# JWT — 64+ char random secret
JWT_SECRET=replace-with-a-very-long-random-secret-string

# Browser origin(s) allowed by the API (must match the public host scheme)
CORS_ALLOWED_ORIGINS=https://coachsim.example.com

# Real cricket API — defaults wired for cricapi.com v2 (https://cricapi.com).
# Sign up for a free API key (100 req/day). For paid ball-by-ball, swap
# base-url + adapter for SportMonks / RapidAPI Cricbuzz.
INGESTION_PROVIDER=external
EXTERNAL_API_BASE_URL=https://api.cricapi.com/v1
EXTERNAL_API_KEY=replace-with-vendor-key

# Backend horizontal scale
BACKEND_REPLICAS=2

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# IMPORTANT: leave COMPOSE_PROFILES unset (or empty).
# Our embedded Traefik in the base compose is gated to the "proxy" profile;
# in prod we use the host's external Traefik, so we DO NOT activate "proxy".
#COMPOSE_PROFILES=
